# Copia questo file in ".env.local" per lo sviluppo in locale.
# In produzione queste variabili si impostano dal pannello di Vercel.

# Stringa di connessione al database Postgres.
# Su Vercel viene impostata automaticamente quando colleghi un database Postgres (Neon).
DATABASE_URL=postgres://utente:password@host/nomedb?sslmode=require

# Chiave segreta per firmare i token di accesso. Usa una stringa lunga e casuale.
# Puoi generarla con:  openssl rand -hex 32
AUTH_SECRET=metti-qui-una-stringa-lunga-e-casuale
